#!/bin/sh
set -u

log="$(mktemp "${TMPDIR:-/tmp}/codex-implement.XXXXXX.jsonl")"
last="$(mktemp "${TMPDIR:-/tmp}/codex-implement.XXXXXX.last")"

cleanup() {
  rm -f "$log" "$last"
}
trap cleanup EXIT INT TERM

codex exec \
  --model "gpt-5.5" \
  -c model_reasoning_effort=medium \
  --json \
  --output-last-message "$last" \
  --sandbox workspace-write \
  --ask-for-approval never \
  --add-dir ~/.gradle \
  --add-dir `pwd -P` \
  "Implement next bead. Use subagents as instructed." >"$log"
status=$?

session_id="$(jq -r 'select(.type == "thread.started") | .thread_id' "$log" | tail -n 1)"

printf 'Session ID: %s\n\n' "$session_id"
printf 'Final agent response:\n'
cat "$last"
printf '\n'
printf 'To inspect session: codex resume %s\n' "$session_id"

exit "$status"
